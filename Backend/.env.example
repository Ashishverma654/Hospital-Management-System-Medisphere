# Port configuration
PORT=3500

# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# JWT secrets
JWT_SECRET=your_jwt_secret_here
REFRESH_SECRET=your_refresh_secret_here

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3500

# Cloudinary configuration
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET=your_cloudinary_secret

# Email configuration
EMAIL_PROVIDER=smtp # or resend
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password_or_app_password

# Resend configuration (if using resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=onboarding@resend.dev

# Super Admin initial credentials
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=YourSecurePassword123

# Timezone offset (e.g., 330 for IST)
HOSPITAL_TZ_OFFSET_MINUTES=330

# CORS settings
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-frontend.com

# Queue / no-show tuning
NO_SHOW_ENABLED=true
NO_SHOW_GRACE_MINUTES=10
NO_SHOW_INTERVAL_MINUTES=5
QUEUE_AVG_WAIT_MINUTES=10

# SMTP settings (if using smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FORCE_IPV4=true
